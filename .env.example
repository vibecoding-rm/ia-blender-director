# Copy to .env and fill in your values

# OpenRouter API key (https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ComfyUI server URL (default: local)
COMFY_URL=http://127.0.0.1:8188

# Blender executable name or full path
BLENDER_EXECUTABLE=blender

# FastAPI server settings
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# ── Voz (TTS) ────────────────────────────────────────────────────────────────
# Motor de síntesis: piper (por defecto, local) | xtts (Coqui, clonación es) |
# command (plantilla libre para OpenVoice/Fish). Cualquier fallo cae a piper.
TTS_ENGINE=piper
# Muestra de referencia para clonar voz (xtts/command). WAV de 6-10s.
# TTS_SPEAKER_WAV=assets/voices/cotorra_ref.wav
TTS_LANGUAGE=es
# Para TTS_ENGINE=command: plantilla con placeholders {text} {out} {ref}
# TTS_COMMAND=mi-tts --text "{text}" --ref "{ref}" --out "{out}"

# ── Lip-sync ─────────────────────────────────────────────────────────────────
# El lip-sync usa el binario `rhubarb` (instálalo y ponlo en el PATH).
# Sin él, La Cotorra usa la animación Talk embebida (degradación elegante).

# ── Director Agent ───────────────────────────────────────────────────────────
# Para la ruta endurecida con Instructor: pip install -e ".[director]"

# ── Vast.ai (alquiler de GPU) ────────────────────────────────────────────────
# La key NUNCA va al repo: ponla solo en tu .env local (este archivo es ejemplo).
# VAST_API_KEY=tu_api_key_de_vast_ai
